{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bvlsupport.local/schemas/features.schema.json",
  "title": "BVL Support Features Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections", "items"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "enum": ["dark", "light"]
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["dark", "light"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "icon"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string",
            "minLength": 1,
            "description": "Icon alias (tool, chart, file, monitor, activity, brain, zap) or full Iconify name (e.g. material-symbols:bolt-rounded)."
          }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "section", "status", "icon"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string"
          },
          "section": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["published", "coming-soon"]
          },
          "icon": {
            "type": "string",
            "minLength": 1,
            "description": "Icon alias (tool, chart, file, monitor, activity, brain, zap) or full Iconify name (e.g. material-symbols:bolt-rounded)."
          },
          "newTab": {
            "type": "boolean"
          }
        }
      }
    }
  }
}